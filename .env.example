# ─── Database ───────────────────────────────────────────────────
# Supabase direct connection URL (used by Prisma — NOT the pooler)
# Get from: Supabase Dashboard → Settings → Database → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.qjjetqtzexiydyfqohih.supabase.co:5432/postgres"

# Supabase public keys (used by supabase-js on the frontend)
NEXT_PUBLIC_SUPABASE_URL="https://qjjetqtzexiydyfqohih.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# ─── Auth (Admin) ────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"

