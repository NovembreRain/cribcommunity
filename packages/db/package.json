{
  "name": "@crib/db",
  "version": "0.0.1",
  "private": true,
  "prisma": {
    "schema": "schema.prisma"
  },
  "scripts": {
    "db:generate": "prisma generate --schema=schema.prisma",
    "db:push": "prisma db push --schema=schema.prisma",
    "db:pull": "prisma db pull --schema=schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=schema.prisma",
    "db:studio": "prisma studio --schema=schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
